# Line styles
set border 3 linewidth 1
set style line 1 linetype 1 linewidth 2  dashtype 2 lc rgb "red" # line style 1
set style line 2 linetype 1 linewidth 2  dashtype 3 lc rgb "blue" # ls2
set style line 3 linetype 1 linewidth 2  dashtype 1 lc rgb "black"# ls3
set style line 4 linetype 1 linewidth 2  dashtype 5 lc rgb "pink" # ls3